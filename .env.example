# SPX/SPY Options Trading Bot Dashboard - Configuration

# Server Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DEBUG=True

# Trading Engine Configuration
TRADING_ENGINE_URL=http://localhost:8001
TRADING_ENGINE_API_KEY=your_api_key_here

# Market Data Provider
MARKET_DATA_URL=http://localhost:8002
MARKET_DATA_API_KEY=your_market_data_key

# Options Flow Provider
OPTIONS_FLOW_URL=http://localhost:8003
OPTIONS_FLOW_API_KEY=your_flow_key

# WebSocket Configuration
WEBSOCKET_HEARTBEAT_INTERVAL=30  # seconds
WEBSOCKET_MAX_RECONNECT_ATTEMPTS=5
WEBSOCKET_RECONNECT_DELAY_MS=1000

# UI Configuration
THEME=dark
CURRENCY=USD
TIMEZONE=US/Eastern

# Notification Settings
SOUND_ALERTS_ENABLED=True
SOUND_ALERT_CONFIDENCE_THRESHOLD=75  # percent
TOAST_NOTIFICATION_DURATION=4000  # milliseconds

# Chart Configuration
PNL_CHART_DAYS=30  # days of history to display
REFRESH_MARKET_DATA_INTERVAL=5000  # milliseconds
REFRESH_ALL_DATA_INTERVAL=30000  # milliseconds

# Trading Configuration
PATTERN_DAY_TRADER_LIMIT=3
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PERCENT=2.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=dashboard.log
